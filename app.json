{
  "expo": {
    "name": "Todododo",
    "slug": "todododo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "todododo",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.todododo.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.todododo.app"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro",
      "port": 3000
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "d213d6fa-49c2-4b4d-bff7-b3b53597a511"
      }
    }
  }
}